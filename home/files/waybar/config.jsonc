{
    "layer": "top",
    "modules-left": ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["mpris", "group/connectivity", "pulseaudio", "group/power", "group/controls", "tray", "custom/power", "clock"],
    "hyprland/workspaces": {
        "format": "{name}",
        "on-double-click": "~/.config/waybar/scripts/rename-workspace.sh"
    },
    "hyprland/window": {
        "max-length": 50
    },
    "mpris": {
        "format": "{player_icon} {title} â€” {artist}",
        "format-paused": "{status_icon} {title} â€” {artist}",
        "player-icons": {
            "default": "â–¶",
            "spotify": ""
        },
        "status-icons": {
            "paused": "âڈ¸"
        },
        "max-length": 40,
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous"
    },
    "group/connectivity": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": false
        },
        "modules": ["network", "bluetooth", "custom/tailscale"]
    },
    "group/power": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": false
        },
        "modules": ["battery", "power-profiles-daemon"]
    },
    "group/controls": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": false
        },
        "modules": ["idle_inhibitor", "custom/dnd", "custom/clipboard"]
    },
    "bluetooth": {
        "format": "َ°‚¯",
        "format-connected": "َ°‚± {device_alias}",
        "format-off": "َ°‚²",
        "tooltip-text": "{controller_alias} ({controller_address})\n{num_connections} connected",
        "on-click": "blueman-manager"
    },
    "custom/tailscale": {
        "exec": "~/.config/waybar/scripts/tailscale-status.sh",
        "return-type": "json",
        "interval": 5,
        "on-click": "~/.config/waybar/scripts/tailscale-menu.sh",
        "tooltip": true
    },
    "network": {
        "format-wifi": "َ°–©",
        "format-ethernet": "َ°ˆ€",
        "format-disconnected": "َ°–ھ",
        "tooltip-format-wifi": "{essid}\n{ipaddr}\nSignal: {signalStrength}%\nGateway: {gwaddr}\nâ†‘ {bandwidthUpBits}  â†“ {bandwidthDownBits}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}\nGateway: {gwaddr}\nâ†‘ {bandwidthUpBits}  â†“ {bandwidthDownBits}",
        "tooltip-format-disconnected": "No connection",
        "on-click": "~/.config/waybar/scripts/wifi-menu.sh"
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-muted": "َ°‌ں Muted",
        "format-icons": {
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol",
        "on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "scroll-step": 5
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["", "", "", "", ""],
        "format-charging": "{capacity}% َ°‚„",
        "format-plugged": "{capacity}% َ°ڑ¥",
        "states": {
            "warning": 30,
            "critical": 15
        },
        "tooltip-text": "{timeTo}",
        "on-click": "kitty --hold -e sh -c 'upower -i $(upower -e | grep battery | head -1)'"
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-text": "{profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default":      "َ°ˆگ",
            "performance":  "َ°“…",
            "balanced":     "َ°¾…",
            "power-saver":  "َ°¾†"
        }
    },
    "tray": {
        "spacing": 8
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°’³",
            "deactivated": "َ°’²"
        }
    },
    "custom/dnd": {
        "exec": "makoctl mode | grep -q do-not-disturb && echo '{\"text\":\"َ°‚›\",\"class\":\"dnd\"}' || echo '{\"text\":\"َ°‚ڑ\"}'",
        "return-type": "json",
        "interval": 2,
        "on-click": "sh -c 'makoctl mode | grep -q do-not-disturb && makoctl mode -r do-not-disturb || makoctl mode -a do-not-disturb'",
        "tooltip": false
    },
    "custom/clipboard": {
        "format": "َ°…چ",
        "on-click": "~/.config/waybar/scripts/clipboard.sh",
        "tooltip": false
    },
    "custom/power": {
        "format": "âڈ»",
        "on-click": "~/.config/waybar/scripts/power-menu.sh",
        "tooltip": false
    },
    "clock": {
        "format-alt": "{:%a, %d. %b  %H:%M}"
    }
}
